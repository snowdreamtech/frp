{
  "ignores": [
    ".ansible/**",
    ".git",
    "node_modules",
    ".venv",
    "venv",
    "env",
    "vendor",
    "dist",
    "build",
    "out",
    "target",
    ".next",
    ".nuxt",
    "__pycache__",
    ".specify",
    // Ignore symlinked AI IDE command/prompt files in all hidden directories
    ".*/commands/**/*.md",
    ".*/prompts/**/*.md",
    // Ignore CHANGELOG.md files in all directories (generated by release-please)
    "CHANGELOG.md",
    "**/CHANGELOG.md",
    // Ignore other common files that cause unnecessary lint errors
    "CODE_OF_CONDUCT.md",
    "LICENSE.md",
    "**/LICENSE.md",
    ".github/ISSUE_TEMPLATE/*.md",
    ".github/PULL_REQUEST_TEMPLATE.md",
    "SECURITY.md",
    "SUPPORT.md",
    "coverage/**",
    ".replit.agent.md",
    "codex.md",
    "AGENTS.md",
    "CLAUDE.md",
    "GEMINI.md"
  ]
}
