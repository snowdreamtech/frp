{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "packages": {
    "docker/alpine": {
      "release-type": "simple",
      "component": "alpine",
      "include-component-in-tag": true,
      "release-as": "3.24.0",
      "changelog-path": "CHANGELOG.md",
      "exclude-paths": ["docker/alpine/CHANGELOG.md"],
      "extra-files": [
        {
          "type": "generic",
          "path": "Dockerfile",
          "glob": false
        }
      ]
    },
    "docker/debian": {
      "release-type": "simple",
      "component": "debian",
      "include-component-in-tag": true,
      "release-as": "13.5.0",
      "changelog-path": "CHANGELOG.md",
      "exclude-paths": ["docker/debian/CHANGELOG.md"],
      "extra-files": [
        {
          "type": "generic",
          "path": "Dockerfile",
          "glob": false
        }
      ]
    },
    "docker/rocky": {
      "release-type": "simple",
      "component": "rocky",
      "include-component-in-tag": true,
      "release-as": "10.2.0",
      "changelog-path": "CHANGELOG.md",
      "exclude-paths": ["docker/rocky/CHANGELOG.md"],
      "extra-files": [
        {
          "type": "generic",
          "path": "Dockerfile",
          "glob": false
        }
      ]
    }
  },
  "include-v-in-tag": true,
  "bump-minor-pre-major": true,
  "bump-patch-for-minor-pre-major": true,
  "pull-request-title-pattern": "chore(release): ${component} ${version} 🚀",
  "pull-request-header": "## 📦 Release Preparation\n\nThis PR was autogenerated by [release-please](https://github.com/googleapis/release-please). \n\n### ⚠️ Critical Actions Before Merging\n\n1. **Verify Quality**: Ensure all CI checks (Lint, Test, Security) are passing.\n2. **Review Changelog**: Confirm that the generated notes below accurately reflect the changes.\n3. **Sanity Check**: If this is a major version, verify that breaking changes are correctly documented.\n\nMerging this PR will create a GitHub Release and a Git Tag. 🚀",
  "changelog-sections": [
    {
      "type": "breaking",
      "section": "💥 BREAKING CHANGES",
      "hidden": false
    },
    {
      "type": "security",
      "section": "🛡️ Security Updates",
      "hidden": false
    },
    {
      "type": "sec",
      "section": "🛡️ Security Updates",
      "hidden": false
    },
    {
      "type": "feat",
      "section": "🚀 Features",
      "hidden": false
    },
    {
      "type": "fix",
      "section": "🐛 Bug Fixes",
      "hidden": false
    },
    {
      "type": "perf",
      "section": "⚡️ Performance Improvements",
      "hidden": false
    },
    {
      "type": "refactor",
      "section": "🛠 Refactoring",
      "hidden": false
    },
    {
      "type": "docs",
      "section": "📖 Documentation",
      "hidden": false
    },
    {
      "type": "chore",
      "section": "♻️ Miscellaneous Chores",
      "hidden": false
    }
  ],
  "separate-pull-requests": false
}
